{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/api-server/src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "artifacts/alunos-dashboard/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/public"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "artifacts/api-server/src/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "artifacts/alunos-dashboard/$1"
    }
  ]
}
